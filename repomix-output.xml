  bool _isProcessing = false;

  Future<void> _handleCheckout() async {
    final auth = context.read<AuthProvider>();

    // Guard: pastikan user masih punya token
    if (auth.token == null) {
      _showSnackbar('Sesi habis. Silakan login kembali.', isError: true);
      return;
    }

    final confirmed = await _showCheckoutConfirmDialog();
    if (!confirmed || !mounted) return;

    setState(() => _isProcessing = true);

    try {
      // Simulasi POST /orders ke backend
      // Saat backend siap, ganti dengan API call:
      //
      // final orderService = context.read<IOrderService>();
      // await orderService.createOrder(
      //   token:  auth.token!,
      //   items:  widget.cart.items,
      // );

      await Future.delayed(const Duration(seconds: 2)); // Mock delay

      if (!mounted) return;
      widget.cart.clearCart();
      _showSuccessDialog();
    } catch (e) {
      if (!mounted) return;
      _showSnackbar('Checkout gagal. Coba lagi.', isError: true);
