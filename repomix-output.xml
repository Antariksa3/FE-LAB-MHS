  Widget _buildLoginButton(BuildContext context) {
    return Consumer<AuthProvider>(
      builder: (_, auth, __) {
        final isLoading = auth.status == AuthStatus.loading;
        return GoldButton(
          label: isLoading ? 'Signing in...' : 'Sign In',
          isLoading: isLoading,
          onPressed: isLoading ? null : _handleEmailLogin,
